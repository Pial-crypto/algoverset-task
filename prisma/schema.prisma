// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

model Todo {
  id   Int    @id @default(autoincrement())
  name String
}


model Tour {
  id               String   @id @default(uuid())
  title            String
  image            String
  rating           Float
  reviews          Int
  location         String
  price            Float
  originalPrice    Float?
  discount         Float?
  duration         Int
  experiences      Int
  description      String
  language         String[]
  ageGroup         String
  includes         String[]
  freeBooking      Boolean
  premiumInclusion Boolean
  tourType         String
  region           String
  adventureStyle   String[]
  startDate        DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([region])
  @@index([price])
  @@index([duration])
  @@index([rating])
  @@index([reviews])
  @@index([startDate])

  @@index([region, price])
  @@index([region, duration])

  @@index([language], type: Gin)
  @@index([adventureStyle], type: Gin)
}